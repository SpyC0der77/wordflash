{
  "name": "@wordflash/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": ["./dist/index.d.ts", "./src/index.ts"],
      "import": ["./dist/index.js", "./src/index.ts"],
      "require": ["./dist/index.cjs", "./src/index.ts"]
    }
  },
  "scripts": {
    "lint": "tsc --noEmit",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
