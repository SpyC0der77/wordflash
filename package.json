{
  "name": "wordflash-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter wordflash dev",
    "dev:web": "bun run --filter wordflash dev",
    "build": "bun run --filter @wordflash/core build && bun run --filter wordflash build",
    "build:web": "bun run --filter @wordflash/core build && bun run --filter wordflash build",
    "lint": "bun run --filter '*' lint",
    "test": "bun run --filter '*' test",
    "prepare": "bun run --filter @wordflash/core build"
  },
  "devDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "nuqs": "^2.8.9"
  }
}
